# Database
DATABASE_URL=postgresql://user:password@localhost:5432/tanhwe_guest_house
DIRECT_URL=postgresql://user:password@localhost:5432/tanhwe_guest_house

# Cloudflare R2 room-image storage
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=tanhwe-room-images
# Use a production custom domain, e.g. https://images.example.com
R2_PUBLIC_URL=https://your-public-r2-domain.example.com
# Optional during custom-domain migration. Remove after old absolute URLs are replaced.
R2_LEGACY_PUBLIC_URL=https://your-bucket-id.r2.dev

# Authentication
AUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32

# Initial owner (required by `npm run seed`; password must be 12+ characters)
ADMIN_EMAIL=admin@tanhweguesthouse.com
ADMIN_PASSWORD=replace-with-a-unique-12-plus-character-password

# Resend (for email notifications)
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=no-reply@tanhweguesthouse.com

# Sentry (for error tracking)
SENTRY_DSN=your-sentry-dsn

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Vercel Cron authentication (generate a long random value)
CRON_SECRET=replace-with-a-long-random-secret
