# Database
DATABASE_URL=postgresql://user:password@localhost:5432/tanhwe_guest_house
DIRECT_URL=postgresql://user:password@localhost:5432/tanhwe_guest_house

# Supabase (if using Supabase instead of local PostgreSQL)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Authentication
AUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32

# Admin User (optional, defaults to admin@tanhweguesthouse.com/admin123)
ADMIN_EMAIL=admin@tanhweguesthouse.com
ADMIN_PASSWORD=admin123

# Resend (for email notifications)
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=no-reply@tanhweguesthouse.com

# Sentry (for error tracking)
SENTRY_DSN=your-sentry-dsn

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000